rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isSystemAdmin() {
      return isSignedIn() && (request.auth.token.email == "boogiilive@gmail.com");
    }

    // Profiles - Allow any signed-in user to GET any profile (safe for MVP)
    // but only owner can UPDATE.
    match /profiles/{userId} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isSystemAdmin());
    }

    // Companies - Allow any signed-in user to GET company info.
    match /companies/{companyId} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn() && (
        isSystemAdmin() || 
        resource.data.admin_uid == request.auth.uid ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.company_id == companyId
      );

      match /members/{memberId} {
        allow read, get, list: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // Orders - Allow signed-in users to list if they own the order OR are part of the company
    match /orders/{orderId} {
      allow list, get: if isSignedIn() && (
        isSystemAdmin() || 
        resource.data.user_id == request.auth.uid || 
        resource.data.company_id == get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('company_id', 'none')
      );
      allow create: if isSignedIn();
      allow update, delete: if isSystemAdmin();
    }

    // Support collections
    match /profile_views/{id} { allow read, write: if true; }
    match /saved_cards/{id} { allow read, write: if isSignedIn(); }
    match /verified_requests/{id} { allow read, write: if isSignedIn(); }
  }
}
