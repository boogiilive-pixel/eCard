rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Глобал хаалт (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Landing Page stats болон Directory-д зориулж profiles-ийг УНШИХ эрхийг нээх
    match /profiles/{userId} {
      allow read, get, list: if true; // Нийтэд нээлттэй (Landing Page stats-д хэрэгтэй)
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Байгууллагын мэдээллийг нэвтэрсэн хэрэглэгч бүрт нээлттэй байлгах (Dashboard-д хэрэгтэй)
    match /companies/{companyId} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn();
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Захиалгын мэдээлэл
    match /orders/{orderId} {
      allow read, get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.token.email == "boogiilive@gmail.com";
    }

    // Туслах коллекцууд
    match /profile_views/{id} { allow read, write: if true; }
    match /saved_cards/{id} { allow read, write: if isSignedIn(); }
    match /verified_requests/{id} { allow read, write: if isSignedIn(); }
  }
}
